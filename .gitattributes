# Store everything as LF in the repo; check out native per-OS.
* text=auto

# Explicit text types
*.cs      text
*.csproj  text
*.slnx    text
*.sln     text
*.json    text
*.md      text
*.ts      text
*.tsx     text
*.js      text
*.jsx     text
*.html    text
*.css     text
*.yml     text
*.yaml    text
*.http    text
*.svg     text

# Windows-only scripts must stay CRLF
*.ps1     text eol=crlf
*.cmd     text eol=crlf
*.bat     text eol=crlf

# Binary (never touch)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.ico     binary
*.db      binary
*.db-shm  binary
*.db-wal  binary
